---
import type { Lang } from '../i18n/translations';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const llms = [
  { model: 'Sarvam-105B', org: 'Sarvam AI', params: '105B MoE', languages: '22 Indian + EN', notes: 'Govt-backed, open-source, 128K ctx' },
  { model: 'Sarvam-30B', org: 'Sarvam AI', params: '30B MoE', languages: '10+ Indian', notes: 'Lighter, 32K ctx, edge-friendly' },
  { model: 'Krutrim-2', org: 'Ola AI', params: '12B dense', languages: '22 Indian', notes: 'Fast inference, 128K ctx' },
  { model: 'Hanooman', org: 'IIT Bombay + Jio', params: '1.5B–40B', languages: '11 Indian', notes: 'Multimodal: text, speech, video' },
  { model: 'Airavata', org: 'AI4Bharat', params: 'Various', languages: '22 Indian', notes: 'NLP tooling, IndicTrans2' },
  { model: 'BharatGen', org: 'CDAC + IndiaAI', params: 'Various', languages: '22 Indian', notes: 'Govt supercomputing initiative' },
];
---

<section class="llms" id="llms">
  <div class="llms-inner">
    <p class="section-label reveal">{t.llms.headers.model}</p>
    <h2 class="llms-title reveal reveal-delay-1">{t.llms.title}</h2>
    <p class="llms-subtitle reveal reveal-delay-2">{t.llms.subtitle}</p>

    <div class="table-container reveal reveal-delay-3">
      <table>
        <thead>
          <tr>
            <th>{t.llms.headers.model}</th>
            <th>{t.llms.headers.org}</th>
            <th>{t.llms.headers.params}</th>
            <th>{t.llms.headers.languages}</th>
            <th>{t.llms.headers.notes}</th>
          </tr>
        </thead>
        <tbody>
          {llms.map((row) => (
            <tr>
              <td class="td-model">{row.model}</td>
              <td>{row.org}</td>
              <td><code>{row.params}</code></td>
              <td>{row.languages}</td>
              <td class="td-notes">{row.notes}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="disclaimer reveal reveal-delay-4">
      <svg viewBox="0 0 16 16" width="14" height="14" class="disclaimer-icon">
        <circle cx="8" cy="8" r="7" fill="none" stroke="currentColor" stroke-width="1.5"/>
        <line x1="8" y1="5" x2="8" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <circle cx="8" cy="12" r="0.8" fill="currentColor"/>
      </svg>
      <span>{t.llms.disclaimer}</span>
    </div>
  </div>
</section>

<style>
  .llms {
    padding: 6rem var(--gutter);
  }

  .llms-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .llms-title {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    margin-bottom: 0.5rem;
  }

  .llms-subtitle {
    color: var(--color-text-dim);
    font-size: 1rem;
    margin-bottom: 3rem;
    max-width: 36rem;
  }

  .table-container {
    overflow-x: auto;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: var(--color-surface);
    -webkit-overflow-scrolling: touch;
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  thead {
    border-bottom: 1px solid var(--color-border-light);
  }

  th {
    padding: 0.85rem 1.25rem;
    text-align: left;
    font-family: var(--font-mono), monospace;
    font-weight: 500;
    font-size: 0.7rem;
    color: var(--color-text-dim);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    white-space: nowrap;
    opacity: 0.7;
  }

  td {
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
    font-size: 0.9rem;
    vertical-align: top;
    color: var(--color-text-dim);
  }

  tbody tr:last-child td { border-bottom: none; }

  tbody tr {
    transition: background 0.2s ease;
  }

  tbody tr:hover {
    background: var(--color-surface-hover);
  }

  .td-model {
    font-family: var(--font-mono), monospace;
    font-weight: 500;
    color: var(--color-accent);
    white-space: nowrap;
  }

  code {
    background: var(--color-gold-dim);
    color: var(--color-gold);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-size: 0.8rem;
    white-space: nowrap;
  }

  .td-notes {
    font-size: 0.85rem;
    opacity: 0.7;
  }

  .disclaimer {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 1.5rem;
    padding: 0.85rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-size: 0.85rem;
    color: var(--color-text-dim);
  }

  .disclaimer-icon {
    color: var(--color-gold);
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    td, th { padding: 0.75rem 0.75rem; }
    td { font-size: 0.82rem; }
  }
</style>
