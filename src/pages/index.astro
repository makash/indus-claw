---
import Layout from '../layouts/Layout.astro';
import LLMTable from '../components/LLMTable.astro';
import SignupForm from '../components/SignupForm.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout>
  <!-- Hero -->
  <section class="hero">
    <!-- Radial glow behind seal -->
    <div class="hero-glow" aria-hidden="true"></div>

    <!-- Animated grid-city background -->
    <div class="hero-grid" aria-hidden="true">
      <svg viewBox="0 0 800 600" preserveAspectRatio="xMidYMid slice" class="grid-svg">
        <defs>
          <radialGradient id="grid-fade" cx="50%" cy="40%" r="60%">
            <stop offset="0%" stop-color="white" stop-opacity="1"/>
            <stop offset="100%" stop-color="white" stop-opacity="0"/>
          </radialGradient>
          <mask id="grid-mask"><rect width="800" height="600" fill="url(#grid-fade)"/></mask>
        </defs>
        <g mask="url(#grid-mask)" stroke="#E8603C" stroke-width="0.5" opacity="0.12">
          {Array.from({length: 13}).map((_, i) => (
            <line x1={i * 66} y1="0" x2={i * 66} y2="600"/>
          ))}
          {Array.from({length: 10}).map((_, i) => (
            <line x1="0" y1={i * 66} x2="800" y2={i * 66}/>
          ))}
        </g>
      </svg>
    </div>

    <div class="hero-inner">
      <div class="hero-content">
        <div class="hero-badge reveal">
          <span class="badge-dot"></span>
          {t.hero.badge}
        </div>

        <h1 class="hero-title reveal reveal-delay-1">
          {t.hero.title}<br />
          <span class="hero-highlight">{t.hero.titleHighlight}</span>
        </h1>

        <p class="hero-subtitle reveal reveal-delay-2">{t.hero.subtitle}</p>
        <p class="hero-desc reveal reveal-delay-3">{t.hero.description}</p>

        <div class="hero-actions reveal reveal-delay-4">
          <a href="#early-access" class="btn-glow">{t.cta.button}<span class="btn-arrow">&rarr;</span></a>
          <a href="#llms" class="btn-outline">{t.llms.title}</a>
        </div>
      </div>

      <!-- Large Harappan Seal -->
      <div class="hero-seal reveal reveal-delay-2" aria-hidden="true">
        <div class="seal-container">
          <svg viewBox="0 0 280 280" class="seal-art">
            <!-- Outer frame with notched corners -->
            <rect x="8" y="8" width="264" height="264" rx="4" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.6"/>
            <rect x="16" y="16" width="248" height="248" rx="2" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.25"/>

            <!-- Grid city plan -->
            <g opacity="0.15" stroke="currentColor" stroke-width="0.5">
              <line x1="56" y1="16" x2="56" y2="264"/>
              <line x1="100" y1="16" x2="100" y2="264"/>
              <line x1="140" y1="16" x2="140" y2="264"/>
              <line x1="180" y1="16" x2="180" y2="264"/>
              <line x1="224" y1="16" x2="224" y2="264"/>
              <line x1="16" y1="56" x2="264" y2="56"/>
              <line x1="16" y1="100" x2="264" y2="100"/>
              <line x1="16" y1="140" x2="264" y2="140"/>
              <line x1="16" y1="180" x2="264" y2="180"/>
              <line x1="16" y1="224" x2="264" y2="224"/>
            </g>

            <!-- Stepped battlement decoration top -->
            <path d="M40 30 L40 24 L48 24 L48 18 L56 18 L56 24 L64 24 L64 30" fill="none" stroke="currentColor" stroke-width="0.8" opacity="0.3"/>
            <path d="M216 30 L216 24 L224 24 L224 18 L232 18 L232 24 L240 24 L240 30" fill="none" stroke="currentColor" stroke-width="0.8" opacity="0.3"/>

            <!-- Central node cluster (abstracted Harappan weights) -->
            <g opacity="0.5">
              <rect x="120" y="120" width="40" height="40" rx="2" fill="currentColor" opacity="0.08"/>
              <rect x="126" y="126" width="28" height="28" rx="1" fill="none" stroke="currentColor" stroke-width="0.8"/>
              <rect x="134" y="134" width="12" height="12" rx="1" fill="currentColor" opacity="0.2"/>
            </g>

            <!-- Corner glyphs (abstracted Indus script) -->
            <g opacity="0.35" stroke="currentColor" fill="none" stroke-width="0.8">
              <path d="M32 40 L44 40 L44 48 M36 44 L44 44"/>
              <path d="M236 40 L248 40 L248 48 M240 44 L248 44"/>
              <path d="M32 240 L44 240 L44 248 M36 244 L44 244"/>
              <path d="M236 240 L248 240 L248 248 M240 244 L248 244"/>
            </g>

            <!-- Pipal leaf motif (simplified) -->
            <path d="M140 80 Q148 68 140 56 Q132 68 140 80Z" fill="currentColor" opacity="0.12"/>
            <path d="M140 224 Q148 212 140 200 Q132 212 140 224Z" fill="currentColor" opacity="0.12"/>

            <!-- Text placeholder (like Indus script on seals) -->
            <g opacity="0.2">
              <rect x="60" y="246" width="8" height="10" rx="1" fill="currentColor"/>
              <rect x="72" y="246" width="6" height="10" rx="1" fill="currentColor"/>
              <rect x="82" y="246" width="10" height="10" rx="1" fill="currentColor"/>
              <rect x="96" y="248" width="7" height="8" rx="1" fill="currentColor"/>
              <rect x="107" y="246" width="5" height="10" rx="1" fill="currentColor"/>
            </g>
          </svg>
          <div class="seal-pulse"></div>
        </div>
      </div>
    </div>

    <!-- Stepped divider -->
    <div class="step-divider" aria-hidden="true">
      <svg viewBox="0 0 1200 24" preserveAspectRatio="none" class="divider-svg">
        <path d="M0 24 L0 16 L25 16 L25 8 L50 8 L50 0 L75 0 L75 8 L100 8 L100 16 L125 16 L125 24 L150 24 L150 16 L175 16 L175 8 L200 8 L200 0 L225 0 L225 8 L250 8 L250 16 L275 16 L275 24 L300 24 L300 16 L325 16 L325 8 L350 8 L350 0 L375 0 L375 8 L400 8 L400 16 L425 16 L425 24 L450 24 L450 16 L475 16 L475 8 L500 8 L500 0 L525 0 L525 8 L550 8 L550 16 L575 16 L575 24 L600 24 L600 16 L625 16 L625 8 L650 8 L650 0 L675 0 L675 8 L700 8 L700 16 L725 16 L725 24 L750 24 L750 16 L775 16 L775 8 L800 8 L800 0 L825 0 L825 8 L850 8 L850 16 L875 16 L875 24 L900 24 L900 16 L925 16 L925 8 L950 8 L950 0 L975 0 L975 8 L1000 8 L1000 16 L1025 16 L1025 24 L1050 24 L1050 16 L1075 16 L1075 8 L1100 8 L1100 0 L1125 0 L1125 8 L1150 8 L1150 16 L1175 16 L1175 24 L1200 24" fill="none" stroke="currentColor" stroke-width="1"/>
      </svg>
    </div>
  </section>

  <!-- About Section -->
  <section class="about" id="about">
    <div class="about-inner">
      <p class="section-label reveal">{t.about.title}</p>
      <h2 class="about-heading reveal reveal-delay-1">{t.about.description}</h2>

      <div class="features">
        {t.about.features.map((feature: string, i: number) => (
          <div class={`feature reveal reveal-delay-${Math.min(i + 1, 4)}`}>
            <div class="feature-index">{String(i + 1).padStart(2, '0')}</div>
            <p class="feature-text">{feature}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <LLMTable lang={lang} />
  <SignupForm lang={lang} />
</Layout>

<style>
  /* Hero */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 8rem var(--gutter) 4rem;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    top: 10%;
    right: 5%;
    width: 40vw;
    height: 40vw;
    max-width: 600px;
    max-height: 600px;
    background: radial-gradient(circle, var(--color-accent-glow) 0%, transparent 70%);
    filter: blur(80px);
    pointer-events: none;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .grid-svg {
    width: 100%;
    height: 100%;
  }

  .hero-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-content { position: relative; z-index: 1; }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem 0.4rem 0.75rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: 100px;
    font-family: var(--font-mono), monospace;
    font-size: 0.75rem;
    color: var(--color-accent);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 2rem;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 var(--color-accent-glow); }
    50% { opacity: 0.6; box-shadow: 0 0 0 6px transparent; }
  }

  .hero-title {
    font-size: clamp(3rem, 7vw, 5.5rem);
    color: var(--color-text);
    margin-bottom: 1.5rem;
    line-height: 1.05;
  }

  .hero-highlight {
    color: var(--color-accent);
    font-style: italic;
  }

  .hero-subtitle {
    font-family: var(--font-mono), monospace;
    font-size: 0.85rem;
    color: var(--color-gold);
    letter-spacing: 0.04em;
    margin-bottom: 1rem;
  }

  .hero-desc {
    font-size: 1.05rem;
    color: var(--color-text-dim);
    max-width: 32rem;
    margin-bottom: 2.5rem;
    line-height: 1.75;
    font-weight: 300;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn-glow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 2rem;
    background: var(--color-accent);
    color: var(--color-bg);
    border-radius: 8px;
    font-family: var(--font-sans), system-ui, sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.3s ease;
    box-shadow: 0 0 30px var(--color-accent-glow), 0 4px 20px rgba(0,0,0,0.3);
  }
  .btn-glow:hover {
    background: var(--color-accent-hover);
    color: var(--color-bg);
    transform: translateY(-1px);
    box-shadow: 0 0 50px var(--color-accent-glow), 0 8px 30px rgba(0,0,0,0.4);
  }
  .btn-glow .btn-arrow {
    transition: transform 0.2s;
  }
  .btn-glow:hover .btn-arrow { transform: translateX(3px); }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    padding: 0.85rem 2rem;
    border: 1px solid var(--color-border-light);
    border-radius: 8px;
    color: var(--color-text-dim);
    font-family: var(--font-sans), system-ui, sans-serif;
    font-weight: 500;
    font-size: 0.95rem;
    transition: all 0.3s ease;
  }
  .btn-outline:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
    background: var(--color-gold-dim);
  }

  /* Seal */
  .hero-seal {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .seal-container {
    position: relative;
    width: clamp(200px, 22vw, 320px);
    aspect-ratio: 1;
    color: var(--color-accent);
    animation: seal-float 8s ease-in-out infinite;
  }

  @keyframes seal-float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-12px) rotate(1deg); }
  }

  .seal-art {
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 0 40px var(--color-accent-glow));
  }

  .seal-pulse {
    position: absolute;
    inset: -20%;
    border-radius: 50%;
    border: 1px solid var(--color-accent);
    opacity: 0;
    animation: seal-ring 4s ease-out infinite;
  }

  @keyframes seal-ring {
    0% { transform: scale(0.6); opacity: 0.3; }
    100% { transform: scale(1.1); opacity: 0; }
  }

  /* Stepped divider */
  .step-divider {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    color: var(--color-border);
    line-height: 0;
  }

  .divider-svg {
    width: 100%;
    height: 24px;
  }

  /* About */
  .about {
    padding: 6rem var(--gutter);
  }

  .about-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .about-heading {
    font-size: clamp(1.5rem, 3.5vw, 2.5rem);
    max-width: 48rem;
    margin-bottom: 4rem;
    color: var(--color-text);
    line-height: 1.3;
  }

  .features {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
  }

  .feature {
    display: flex;
    gap: 1rem;
    padding: 1.5rem 1.75rem;
    background: var(--color-surface);
    transition: background 0.3s ease;
  }

  .feature:hover {
    background: var(--color-surface-hover);
  }

  .feature-index {
    font-family: var(--font-mono), monospace;
    font-size: 0.7rem;
    color: var(--color-accent);
    opacity: 0.6;
    flex-shrink: 0;
    padding-top: 0.25rem;
    letter-spacing: 0.05em;
  }

  .feature-text {
    font-size: 0.92rem;
    color: var(--color-text-dim);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding: 7rem var(--gutter) 3rem;
    }

    .hero-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .hero-seal { order: -1; }

    .seal-container {
      width: 160px;
    }

    .hero-glow {
      top: 0;
      right: -20%;
      width: 80vw;
      height: 80vw;
    }

    .features {
      grid-template-columns: 1fr;
    }
  }
</style>
