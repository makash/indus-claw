---
import Layout from '../../layouts/Layout.astro';
import LLMTable from '../../components/LLMTable.astro';
import SignupForm from '../../components/SignupForm.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<Layout>
  <section class="hero"><div class="hero-glow" aria-hidden="true"></div><div class="hero-inner"><div class="hero-content"><div class="hero-badge reveal"><span class="badge-dot"></span>{t.hero.badge}</div><h1 class="hero-title reveal reveal-delay-1">{t.hero.title}<br /><span class="hero-highlight">{t.hero.titleHighlight}</span></h1><p class="hero-subtitle reveal reveal-delay-2">{t.hero.subtitle}</p><p class="hero-desc reveal reveal-delay-3">{t.hero.description}</p><div class="hero-actions reveal reveal-delay-4"><a href="#early-access" class="btn-glow">{t.cta.button}<span class="btn-arrow">&rarr;</span></a><a href="#llms" class="btn-outline">{t.llms.title}</a></div></div></div></section>
  <section class="about" id="about"><div class="about-inner"><p class="section-label reveal">{t.about.title}</p><h2 class="about-heading reveal reveal-delay-1">{t.about.description}</h2><div class="features">{t.about.features.map((feature: string, i: number) => (<div class={`feature reveal reveal-delay-${Math.min(i + 1, 4)}`}><div class="feature-index">{String(i + 1).padStart(2, '0')}</div><p class="feature-text">{feature}</p></div>))}</div></div></section>
  <LLMTable lang={lang} /><SignupForm lang={lang} />
</Layout>
<style>.hero{position:relative;min-height:100vh;display:flex;align-items:center;padding:8rem var(--gutter) 4rem;overflow:hidden}.hero-glow{position:absolute;top:10%;right:5%;width:40vw;height:40vw;max-width:600px;max-height:600px;background:radial-gradient(circle,var(--color-accent-glow) 0%,transparent 70%);filter:blur(80px);pointer-events:none}.hero-inner{max-width:var(--max-w);margin:0 auto;width:100%}.hero-content{position:relative;z-index:1;max-width:40rem}.hero-badge{display:inline-flex;align-items:center;gap:.5rem;padding:.4rem 1rem .4rem .75rem;background:var(--color-surface);border:1px solid var(--color-border-light);border-radius:100px;font-family:var(--font-mono),monospace;font-size:.75rem;color:var(--color-accent);letter-spacing:.08em;text-transform:uppercase;margin-bottom:2rem}.badge-dot{width:6px;height:6px;border-radius:50%;background:var(--color-accent);animation:pulse-dot 2s ease-in-out infinite}@keyframes pulse-dot{0%,100%{opacity:1}50%{opacity:.6}}.hero-title{font-size:clamp(3rem,7vw,5.5rem);color:var(--color-text);margin-bottom:1.5rem;line-height:1.05}.hero-highlight{color:var(--color-accent);font-style:italic}.hero-subtitle{font-family:var(--font-mono),monospace;font-size:.85rem;color:var(--color-gold);letter-spacing:.04em;margin-bottom:1rem}.hero-desc{font-size:1.05rem;color:var(--color-text-dim);max-width:32rem;margin-bottom:2.5rem;line-height:1.75;font-weight:300}.hero-actions{display:flex;gap:.75rem;flex-wrap:wrap}.btn-glow{display:inline-flex;align-items:center;gap:.5rem;padding:.85rem 2rem;background:var(--color-accent);color:var(--color-bg);border-radius:8px;font-family:var(--font-sans),system-ui,sans-serif;font-weight:600;font-size:.95rem;transition:all .3s;box-shadow:0 0 30px var(--color-accent-glow),0 4px 20px rgba(0,0,0,.3)}.btn-glow:hover{background:var(--color-accent-hover);color:var(--color-bg)}.btn-outline{display:inline-flex;align-items:center;padding:.85rem 2rem;border:1px solid var(--color-border-light);border-radius:8px;color:var(--color-text-dim);font-family:var(--font-sans),system-ui,sans-serif;font-weight:500;font-size:.95rem;transition:all .3s}.btn-outline:hover{border-color:var(--color-gold);color:var(--color-gold);background:var(--color-gold-dim)}.about{padding:6rem var(--gutter)}.about-inner{max-width:var(--max-w);margin:0 auto}.about-heading{font-size:clamp(1.5rem,3.5vw,2.5rem);max-width:48rem;margin-bottom:4rem;color:var(--color-text);line-height:1.3}.features{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:1px;background:var(--color-border);border:1px solid var(--color-border);border-radius:12px;overflow:hidden}.feature{display:flex;gap:1rem;padding:1.5rem 1.75rem;background:var(--color-surface);transition:background .3s}.feature:hover{background:var(--color-surface-hover)}.feature-index{font-family:var(--font-mono),monospace;font-size:.7rem;color:var(--color-accent);opacity:.6;flex-shrink:0;padding-top:.25rem}.feature-text{font-size:.92rem;color:var(--color-text-dim);line-height:1.6}@media(max-width:768px){.hero{min-height:auto;padding:7rem var(--gutter) 3rem}.features{grid-template-columns:1fr}}</style>
