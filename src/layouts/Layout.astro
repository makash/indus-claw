---
import { Font } from 'astro:assets';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { languages, translatedLocales, type Lang } from '../i18n/translations';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
}

const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);
const hasTranslation = translatedLocales.has(lang);
// For untranslated locales, render as 'en' to avoid Indic fonts on English text
const effectiveLang = hasTranslation ? lang : 'en';
const { title = `IndusClaw — ${t.hero.titleHighlight}`, description = t.hero.description } = Astro.props;

const fontVarMap: Partial<Record<Lang, string>> = {
  hi: '--font-devanagari',
  ta: '--font-tamil',
  te: '--font-telugu',
  bn: '--font-bengali',
  kn: '--font-kannada',
  ml: '--font-malayalam',
  mr: '--font-devanagari',
  gu: '--font-gujarati',
  pa: '--font-gurmukhi',
  or: '--font-oriya',
};
---

<!doctype html>
<html lang={effectiveLang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <title>{title}</title>

    <Font cssVariable="--font-display" preload />
    <Font cssVariable="--font-sans" preload />
    <Font cssVariable="--font-mono" preload />
    {hasTranslation && lang !== 'en' && fontVarMap[lang] && <Font cssVariable={fontVarMap[lang]!} preload />}
  </head>
  <body>
    <!-- Film grain overlay -->
    <div class="grain" aria-hidden="true"></div>

    <nav class="nav">
      <div class="nav-inner">
        <a href={getRelativeLocaleUrl(lang, '/')} class="nav-logo">
          <div class="logo-seal">
            <svg viewBox="0 0 36 36" class="logo-svg">
              <rect x="2" y="2" width="32" height="32" rx="3" fill="none" stroke="currentColor" stroke-width="1.5"/>
              <rect x="6" y="6" width="24" height="24" rx="1" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.4"/>
              <text x="18" y="23" text-anchor="middle" font-size="13" font-weight="700" fill="currentColor" font-family="monospace">IC</text>
            </svg>
          </div>
          <span class="logo-text">IndusClaw</span>
        </a>

        <div class="nav-right">
          <div class="lang-switcher">
            <button class="lang-current" id="lang-toggle" aria-expanded="false">
              {languages[lang]}
              <svg viewBox="0 0 12 12" width="10" height="10" class="lang-chevron"><path d="M3 5l3 3 3-3" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
            <div class="lang-dropdown" id="lang-dropdown">
              {Object.entries(languages).map(([code, name]) => (
                <a
                  href={getRelativeLocaleUrl(code, '/')}
                  class:list={['lang-link', { active: code === lang }]}
                >
                  {name}
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <div class="footer-top">
          <div class="footer-brand">
            <span class="footer-name">IndusClaw</span>
            <span class="footer-sep">/</span>
            <span class="footer-tagline">{t.footer.tagline}</span>
          </div>
        </div>
        <div class="footer-bottom">
          <p>{t.footer.fork}</p>
          <p>{t.footer.built} Astro &middot; Deployed on Cloudflare</p>
        </div>
      </div>
    </footer>

    <script>
      // Language dropdown toggle
      const toggle = document.getElementById('lang-toggle');
      const dropdown = document.getElementById('lang-dropdown');
      toggle?.addEventListener('click', () => {
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!expanded));
        dropdown?.classList.toggle('open');
      });
      document.addEventListener('click', (e) => {
        if (!toggle?.contains(e.target as Node) && !dropdown?.contains(e.target as Node)) {
          toggle?.setAttribute('aria-expanded', 'false');
          dropdown?.classList.remove('open');
        }
      });

      // Scroll reveal
      const reveals = document.querySelectorAll('.reveal');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -60px 0px' });
      reveals.forEach((el) => observer.observe(el));
    </script>
  </body>
</html>

<style is:global>
  :root {
    --color-bg: #110F0D;
    --color-bg-warm: #1A1612;
    --color-surface: #211D18;
    --color-surface-hover: #2A2520;
    --color-text: #E8DFD0;
    --color-text-dim: #A89B8A;
    --color-accent: #E8603C;
    --color-accent-glow: #E8603C40;
    --color-accent-hover: #F07050;
    --color-gold: #C9A456;
    --color-gold-dim: #C9A45630;
    --color-border: #2E2922;
    --color-border-light: #3D362E;
    --max-w: 68rem;
    --gutter: clamp(1.25rem, 4vw, 3rem);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }

  body {
    font-family: var(--font-sans), system-ui, sans-serif;
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.65;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
  }

  :lang(hi), :lang(mr) { font-family: var(--font-devanagari), var(--font-sans), system-ui, sans-serif; }
  :lang(ta) { font-family: var(--font-tamil), var(--font-sans), system-ui, sans-serif; }
  :lang(te) { font-family: var(--font-telugu), var(--font-sans), system-ui, sans-serif; }
  :lang(bn) { font-family: var(--font-bengali), var(--font-sans), system-ui, sans-serif; }
  :lang(kn) { font-family: var(--font-kannada), var(--font-sans), system-ui, sans-serif; }
  :lang(ml) { font-family: var(--font-malayalam), var(--font-sans), system-ui, sans-serif; }
  :lang(gu) { font-family: var(--font-gujarati), var(--font-sans), system-ui, sans-serif; }
  :lang(pa) { font-family: var(--font-gurmukhi), var(--font-sans), system-ui, sans-serif; }
  :lang(or) { font-family: var(--font-oriya), var(--font-sans), system-ui, sans-serif; }

  h1, h2, h3 {
    font-family: var(--font-display), Georgia, serif;
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.01em;
  }

  code, pre { font-family: var(--font-mono), monospace; }

  a {
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.25s ease;
  }
  a:hover { color: var(--color-accent-hover); }

  main { flex: 1; }

  /* Scroll reveal */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.revealed {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }
  .reveal-delay-4 { transition-delay: 0.4s; }

  /* Section shared */
  .section-label {
    font-family: var(--font-mono), monospace;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }
</style>

<style>
  /* Grain overlay */
  .grain {
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 200px;
  }

  /* Navigation */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(17, 15, 13, 0.85);
    backdrop-filter: blur(20px) saturate(1.5);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0.85rem var(--gutter);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    color: var(--color-text);
  }
  .nav-logo:hover { color: var(--color-text); }

  .logo-seal {
    width: 2rem;
    height: 2rem;
    color: var(--color-accent);
    transition: transform 0.3s ease;
  }
  .nav-logo:hover .logo-seal { transform: rotate(3deg) scale(1.05); }

  .logo-svg { width: 100%; height: 100%; }

  .logo-text {
    font-family: var(--font-display), Georgia, serif;
    font-size: 1.2rem;
    letter-spacing: 0.01em;
  }

  /* Language dropdown */
  .nav-right { display: flex; align-items: center; }

  .lang-switcher { position: relative; }

  .lang-current {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: none;
    border: 1px solid var(--color-border);
    color: var(--color-text-dim);
    padding: 0.35rem 0.75rem;
    border-radius: 6px;
    font-family: inherit;
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .lang-current:hover {
    border-color: var(--color-border-light);
    color: var(--color-text);
  }
  .lang-chevron { transition: transform 0.2s; }
  .lang-current[aria-expanded="true"] .lang-chevron { transform: rotate(180deg); }

  .lang-dropdown {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: 8px;
    padding: 4px;
    min-width: 8rem;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: all 0.2s ease;
    box-shadow: 0 12px 40px rgba(0,0,0,0.5);
  }
  .lang-dropdown.open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .lang-link {
    display: block;
    padding: 0.4rem 0.75rem;
    font-size: 0.8rem;
    border-radius: 5px;
    color: var(--color-text-dim);
    transition: all 0.15s;
  }
  .lang-link:hover { background: var(--color-bg-warm); color: var(--color-text); }
  .lang-link.active { color: var(--color-accent); background: var(--color-accent-glow); }

  /* Footer */
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 3rem var(--gutter) 2rem;
    margin-top: 6rem;
  }

  .footer-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .footer-top { margin-bottom: 1.5rem; }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .footer-name {
    font-family: var(--font-display), Georgia, serif;
    font-size: 1.1rem;
    color: var(--color-text);
  }

  .footer-sep { color: var(--color-border-light); }

  .footer-tagline {
    font-size: 0.9rem;
    color: var(--color-text-dim);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: 0.8rem;
    color: var(--color-text-dim);
    opacity: 0.6;
  }

  @media (max-width: 640px) {
    .footer-bottom { flex-direction: column; }
  }
</style>
