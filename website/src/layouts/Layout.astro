---
import { Font } from 'astro:assets';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { languages, translatedLocales, type Lang } from '../i18n/translations';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const issueMap: Partial<Record<Lang, string>> = {
  kn: 'https://github.com/makash/indus-claw/issues/1',
  ml: 'https://github.com/makash/indus-claw/issues/2',
  mr: 'https://github.com/makash/indus-claw/issues/3',
  gu: 'https://github.com/makash/indus-claw/issues/4',
  pa: 'https://github.com/makash/indus-claw/issues/5',
  or: 'https://github.com/makash/indus-claw/issues/6',
};

interface Props {
  title?: string;
  description?: string;
}

const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);
const hasTranslation = translatedLocales.has(lang);
// For untranslated locales, render as 'en' to avoid Indic fonts on English text
const effectiveLang = hasTranslation ? lang : 'en';
const { title = `IndusClaw — ${t.hero.titleHighlight}`, description = t.hero.description } = Astro.props;

const fontVarMap: Partial<Record<Lang, string>> = {
  hi: '--font-devanagari',
  ta: '--font-tamil',
  te: '--font-telugu',
  bn: '--font-bengali',
  kn: '--font-kannada',
  ml: '--font-malayalam',
  mr: '--font-devanagari',
  gu: '--font-gujarati',
  pa: '--font-gurmukhi',
  or: '--font-oriya',
};
---

<!doctype html>
<html lang={effectiveLang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <title>{title}</title>

    <Font cssVariable="--font-display" preload />
    <Font cssVariable="--font-sans" preload />
    <Font cssVariable="--font-mono" preload />
    {hasTranslation && lang !== 'en' && fontVarMap[lang] && <Font cssVariable={fontVarMap[lang]!} preload />}
  </head>
  <body>
    <!-- Film grain overlay -->
    <div class="grain" aria-hidden="true"></div>

    <nav class="nav">
      <div class="nav-inner">
        <a href={getRelativeLocaleUrl(lang, '/')} class="nav-logo">
          <div class="logo-seal">
            <svg viewBox="0 0 36 36" class="logo-svg">
              <rect x="2" y="2" width="32" height="32" rx="3" fill="none" stroke="currentColor" stroke-width="1.5"/>
              <rect x="6" y="6" width="24" height="24" rx="1" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.4"/>
              <text x="18" y="23" text-anchor="middle" font-size="13" font-weight="700" fill="currentColor" font-family="monospace">IC</text>
            </svg>
          </div>
          <span class="logo-text">IndusClaw</span>
        </a>

        <div class="nav-right">
          <div class="lang-switcher">
            <button class="lang-current" id="lang-toggle" aria-expanded="false">
              {languages[lang]}
              <svg viewBox="0 0 12 12" width="10" height="10" class="lang-chevron"><path d="M3 5l3 3 3-3" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
            <div class="lang-dropdown" id="lang-dropdown">
              {Object.entries(languages).map(([code, name]) => {
                const isTranslated = translatedLocales.has(code);
                const issue = issueMap[code as Lang];
                return isTranslated ? (
                  <a
                    href={getRelativeLocaleUrl(code, '/')}
                    class:list={['lang-link', { active: code === lang }]}
                  >
                    {name}
                  </a>
                ) : (
                  <a
                    href={issue || '#'}
                    target={issue ? '_blank' : undefined}
                    rel={issue ? 'noopener' : undefined}
                    class="lang-link lang-link--pending"
                    title={`${name} — translation not ready yet. Help translate!`}
                  >
                    {name}
                    <span class="lang-wip">help translate</span>
                  </a>
                );
              })}
            </div>
          </div>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <p class="footer-by">by <a href="https://x.com/makash?utm_source=indusclaw&utm_medium=web&utm_campaign=footer" target="_blank" rel="noopener">@makash</a></p>
        <div class="footer-links">
          <a href="https://github.com/makash/indus-claw?utm_source=indusclaw&utm_medium=web&utm_campaign=footer" target="_blank" rel="noopener">{t.footer.fork}</a>
          <span class="footer-sep">&middot;</span>
          <a href="https://github.com/makash/indus-claw?utm_source=indusclaw&utm_medium=web&utm_campaign=footer" target="_blank" rel="noopener">Open Source</a>
        </div>
        <div class="footer-social">
          <a href="https://x.com/makash?utm_source=indusclaw&utm_medium=web&utm_campaign=branding" target="_blank" rel="noopener" aria-label="X / Twitter">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://github.com/makash?utm_source=indusclaw&utm_medium=web&utm_campaign=branding" target="_blank" rel="noopener" aria-label="GitHub">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
          </a>
          <a href="https://www.linkedin.com/in/akashm/?utm_source=indusclaw&utm_medium=web&utm_campaign=branding" target="_blank" rel="noopener" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://www.youtube.com/@makash?utm_source=indusclaw&utm_medium=web&utm_campaign=branding" target="_blank" rel="noopener" aria-label="YouTube">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
      </div>
    </footer>

    <script>
      // Language dropdown toggle
      const toggle = document.getElementById('lang-toggle');
      const dropdown = document.getElementById('lang-dropdown');
      toggle?.addEventListener('click', () => {
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!expanded));
        dropdown?.classList.toggle('open');
      });
      document.addEventListener('click', (e) => {
        if (!toggle?.contains(e.target as Node) && !dropdown?.contains(e.target as Node)) {
          toggle?.setAttribute('aria-expanded', 'false');
          dropdown?.classList.remove('open');
        }
      });

      // Scroll reveal
      const reveals = document.querySelectorAll('.reveal');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -60px 0px' });
      reveals.forEach((el) => observer.observe(el));
    </script>
  </body>
</html>

<style is:global>
  :root {
    --color-bg: #110F0D;
    --color-bg-warm: #1A1612;
    --color-surface: #211D18;
    --color-surface-hover: #2A2520;
    --color-text: #E8DFD0;
    --color-text-dim: #A89B8A;
    --color-accent: #E8603C;
    --color-accent-glow: #E8603C40;
    --color-accent-hover: #F07050;
    --color-gold: #C9A456;
    --color-gold-dim: #C9A45630;
    --color-border: #2E2922;
    --color-border-light: #3D362E;
    --max-w: 68rem;
    --gutter: clamp(1.25rem, 4vw, 3rem);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }

  body {
    font-family: var(--font-sans), system-ui, sans-serif;
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.65;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
  }

  :lang(hi), :lang(mr) { font-family: var(--font-devanagari), var(--font-sans), system-ui, sans-serif; }
  :lang(ta) { font-family: var(--font-tamil), var(--font-sans), system-ui, sans-serif; }
  :lang(te) { font-family: var(--font-telugu), var(--font-sans), system-ui, sans-serif; }
  :lang(bn) { font-family: var(--font-bengali), var(--font-sans), system-ui, sans-serif; }
  :lang(kn) { font-family: var(--font-kannada), var(--font-sans), system-ui, sans-serif; }
  :lang(ml) { font-family: var(--font-malayalam), var(--font-sans), system-ui, sans-serif; }
  :lang(gu) { font-family: var(--font-gujarati), var(--font-sans), system-ui, sans-serif; }
  :lang(pa) { font-family: var(--font-gurmukhi), var(--font-sans), system-ui, sans-serif; }
  :lang(or) { font-family: var(--font-oriya), var(--font-sans), system-ui, sans-serif; }

  h1, h2, h3 {
    font-family: var(--font-display), Georgia, serif;
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.01em;
  }

  code, pre { font-family: var(--font-mono), monospace; }

  a {
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.25s ease;
  }
  a:hover { color: var(--color-accent-hover); }

  main { flex: 1; }

  /* Scroll reveal */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.revealed {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }
  .reveal-delay-4 { transition-delay: 0.4s; }

  /* Section shared */
  .section-label {
    font-family: var(--font-mono), monospace;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }
</style>

<style>
  /* Grain overlay */
  .grain {
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 200px;
  }

  /* Navigation */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(17, 15, 13, 0.85);
    backdrop-filter: blur(20px) saturate(1.5);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0.85rem var(--gutter);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    color: var(--color-text);
  }
  .nav-logo:hover { color: var(--color-text); }

  .logo-seal {
    width: 2rem;
    height: 2rem;
    color: var(--color-accent);
    transition: transform 0.3s ease;
  }
  .nav-logo:hover .logo-seal { transform: rotate(3deg) scale(1.05); }

  .logo-svg { width: 100%; height: 100%; }

  .logo-text {
    font-family: var(--font-display), Georgia, serif;
    font-size: 1.2rem;
    letter-spacing: 0.01em;
  }

  /* Language dropdown */
  .nav-right { display: flex; align-items: center; }

  .lang-switcher { position: relative; }

  .lang-current {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: none;
    border: 1px solid var(--color-border);
    color: var(--color-text-dim);
    padding: 0.35rem 0.75rem;
    border-radius: 6px;
    font-family: inherit;
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .lang-current:hover {
    border-color: var(--color-border-light);
    color: var(--color-text);
  }
  .lang-chevron { transition: transform 0.2s; }
  .lang-current[aria-expanded="true"] .lang-chevron { transform: rotate(180deg); }

  .lang-dropdown {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: 8px;
    padding: 4px;
    min-width: 8rem;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: all 0.2s ease;
    box-shadow: 0 12px 40px rgba(0,0,0,0.5);
  }
  .lang-dropdown.open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .lang-link {
    display: block;
    padding: 0.4rem 0.75rem;
    font-size: 0.8rem;
    border-radius: 5px;
    color: var(--color-text-dim);
    transition: all 0.15s;
  }
  .lang-link:hover { background: var(--color-bg-warm); color: var(--color-text); }
  .lang-link.active { color: var(--color-accent); background: var(--color-accent-glow); }

  .lang-link--pending {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
    opacity: 0.5;
  }
  .lang-link--pending:hover { opacity: 0.8; }

  .lang-wip {
    font-size: 0.6rem;
    font-family: var(--font-mono), monospace;
    color: var(--color-gold);
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  /* Footer */
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 3rem var(--gutter) 2.5rem;
    margin-top: 6rem;
  }

  .footer-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
  }

  .footer-by {
    font-size: 0.9rem;
    color: var(--color-text-dim);
  }

  .footer-by a {
    color: var(--color-text);
    font-weight: 500;
    transition: color 0.2s;
  }

  .footer-by a:hover {
    color: var(--color-accent);
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.8rem;
  }

  .footer-links a {
    color: var(--color-text-dim);
    opacity: 0.6;
    transition: opacity 0.2s;
  }

  .footer-links a:hover {
    opacity: 1;
    color: var(--color-accent);
  }

  .footer-sep { color: var(--color-border-light); }

  .footer-social {
    display: flex;
    gap: 1rem;
    margin-top: 0.25rem;
  }

  .footer-social a {
    color: var(--color-text-dim);
    opacity: 0.4;
    transition: all 0.2s;
  }

  .footer-social a:hover {
    opacity: 1;
    color: var(--color-accent);
    transform: translateY(-1px);
  }
</style>
