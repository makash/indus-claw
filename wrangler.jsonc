{
	"compatibility_date": "2026-03-12",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "indusclaw",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "indusclaw-db",
			"database_id": "placeholder-create-with-wrangler-d1-create"
		}
	]
}
